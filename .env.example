# FocusTime Configuration
# Copy this file to .env and adjust values as needed.

# Default Pomodoro durations (minutes)
FOCUSTIME_WORK_DURATION=25
FOCUSTIME_SHORT_BREAK=5
FOCUSTIME_LONG_BREAK=15
FOCUSTIME_LONG_BREAK_INTERVAL=4

# Database path (default: ./focustime.db)
FOCUSTIME_DB_PATH=./focustime.db

# Logging level (DEBUG, INFO, WARNING, ERROR)
FOCUSTIME_LOG_LEVEL=INFO

# Default energy curve (morning_peak, afternoon_peak, steady)
FOCUSTIME_DEFAULT_ENERGY_CURVE=morning_peak
